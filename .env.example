# Production Environment Variables
NODE_ENV=development

# Server Configuration
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=tickets

# JWT Configuration
JWT_SECRET=your_secret_key

# Cookie httpOnly (JWT no navegador)
# Nome do cookie; deve coincidir com o que o front envia implicitamente (credentials: include).
JWT_COOKIE_NAME=access_token
# Em produção com HTTPS use true. Em localhost HTTP use false.
COOKIE_SECURE=false
# lax = mesmo site ou navegação top-level; none = origens cruzadas (ex.: front :5173 e API :3000), exige COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# CORS Configuration
# Deve ser a origem exata do front (protocolo + host + porta). Obrigatório com credentials: true (sem wildcard).
CORS_ORIGIN=http://localhost:3000
